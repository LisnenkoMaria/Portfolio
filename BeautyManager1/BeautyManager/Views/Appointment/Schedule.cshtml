@model IEnumerable<BeautyManager.Models.Appointment>

@{
    ViewData["Title"] = "Расписание";
}

<div class="page-title">
    <h2>Расписание записей</h2>
    <p>Все записи в салоне</p>
</div>

<div style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); padding: 30px; border-radius: 20px; border: 1px solid rgba(219, 184, 184, 0.2);">
    @if (Model == null || !Model.Any())
    {
        <div style="text-align: center; padding: 60px 20px;">
            <i class="fas fa-calendar-times" style="font-size: 60px; color: #dbb8b8; margin-bottom: 20px;"></i>
            <h3 style="color: #dbb8b8; margin-bottom: 15px;">В расписании пока нет записей</h3>
            <p style="color: #5a4e4a; margin-bottom: 25px;">Вы можете быть первым!</p>
            <a href="@Url.Action("Create", "Appointment")" class="btn">
                <i class="fas fa-plus" style="margin-right: 8px;"></i> Записаться
            </a>
        </div>
    }
    else
    {
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #dbb8b8; color: white;">
                    <th style="padding: 15px; text-align: left;">Дата</th>
                    <th style="padding: 15px; text-align: left;">Время</th>
                    <th style="padding: 15px; text-align: left;">Клиент</th>
                    <th style="padding: 15px; text-align: left;">Услуга</th>
                    <th style="padding: 15px; text-align: left;">Мастер</th>
                    <th style="padding: 15px; text-align: left;">Телефон</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid rgba(219, 184, 184, 0.2);">
                        <td style="padding: 15px;">@item.AppointmentDate.ToString("dd.MM.yyyy")</td>
                        <td style="padding: 15px;">@item.AppointmentTime</td>
                        <td style="padding: 15px;">@item.ClientName</td>
                        <td style="padding: 15px;">@(item.Service?.Name ?? "—")</td>
                        <td style="padding: 15px;">@(item.Master?.Name ?? "—")</td>
                        <td style="padding: 15px;">@item.ClientPhone</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div style="text-align: center; margin-top: 30px;">
    <a href="@Url.Action("Create", "Appointment")" class="btn">
        <i class="fas fa-plus" style="margin-right: 8px;"></i> Новая запись
    </a>
</div>