@{
    ViewData["Title"] = "Запись подтверждена";
}
<div style="max-width: 600px; margin: 50px auto;">
    <div style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); padding: 50px 40px; border-radius: 30px; box-shadow: 0 20px 50px rgba(219, 184, 184, 0.2); border: 1px solid rgba(219, 184, 184, 0.3); text-align: center;">

        <!-- Иконка успеха -->
        <div style="margin-bottom: 30px;">
            <i class="fas fa-check-circle" style="font-size: 90px; color: #dbb8b8;"></i>
        </div>

        <!-- Заголовок -->
        <h2 style="color: #dbb8b8; font-size: 42px; margin-bottom: 20px; font-weight: 300;">
            Спасибо за запись!
        </h2>

        <!-- Текст -->
        <p style="color: #5a4e4a; font-size: 18px; margin-bottom: 40px;">
            Ваша запись успешно создана. Мы свяжемся с вами для подтверждения.
        </p>

        <!-- Кнопки -->
        <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
            <a href="@Url.Action("Index", "Home")"
               style="display: inline-block; padding: 15px 35px; background: linear-gradient(135deg, #dbb8b8, #c9a3a3); color: white; text-decoration: none; border-radius: 30px; font-size: 16px; transition: all 0.3s; box-shadow: 0 4px 15px rgba(219, 184, 184, 0.3);">
                <i class="fas fa-home" style="margin-right: 8px;"></i> На главную
            </a>
            <a href="@Url.Action("Schedule", "Appointment")"
               style="display: inline-block; padding: 15px 35px; background: transparent; color: #dbb8b8; text-decoration: none; border-radius: 30px; font-size: 16px; transition: all 0.3s; border: 2px solid #dbb8b8;">
                <i class="fas fa-calendar-alt" style="margin-right: 8px;"></i> Посмотреть в расписании
            </a>
        </div>
    </div>
</div>