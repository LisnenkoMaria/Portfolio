@{
    ViewData["Title"] = "Контакты";
}

<div class="page-title">
    <h2>Контакты салона МАРМАРА</h2>
    <p>Как нас найти и связаться с нами</p>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); padding: 40px; border-radius: 20px; border: 2px solid rgba(219, 184, 184, 0.3); box-shadow: 0 20px 50px rgba(219, 184, 184, 0.15);">
    <div>
        <h3 style="color: var(--dusty-rose); margin-bottom: 20px;">Мы на карте</h3>
        <div style="background: linear-gradient(135deg, var(--light-blue), var(--peach)); height: 300px; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 2px solid rgba(219, 184, 184, 0.3);">
            <i class="fas fa-map-marked-alt" style="font-size: 50px; color: var(--dusty-rose);"></i>
        </div>
    </div>
    <div>
        <h3 style="color: var(--dusty-rose); margin-bottom: 20px;">Контактная информация</h3>
        <div style="margin-bottom: 30px;">
            <p style="color: var(--text-dark); margin-bottom: 10px;"><i class="fas fa-phone" style="color: var(--dusty-rose); width: 30px;"></i> +7 (999) 123-45-67</p>
            <p style="color: var(--text-dark); margin-bottom: 10px;"><i class="fas fa-envelope" style="color: var(--dusty-rose); width: 30px;"></i> info@marmara.ru</p>
            <p style="color: var(--text-dark); margin-bottom: 10px;"><i class="fas fa-map-marker-alt" style="color: var(--dusty-rose); width: 30px;"></i> ул. Красоты, д. 10</p>
        </div>
        <div>
            <h4 style="color: var(--dusty-rose); margin-bottom: 15px;">Режим работы:</h4>
            <p style="color: var(--text-dark);">Пн-Пт: 10:00 - 21:00</p>
            <p style="color: var(--text-dark);">Сб-Вс: 11:00 - 20:00</p>
        </div>
    </div>
</div>