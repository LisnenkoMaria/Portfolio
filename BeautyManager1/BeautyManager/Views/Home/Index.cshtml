@model IEnumerable<BeautyManager.Models.Service>

@{
    ViewData["Title"] = "Главная";
}

<div class="page-title">
    <h2>Добро пожаловать в салон МАРМАРА</h2>
    <p>Ваша красота - наша работа</p>
</div>

<!-- БАННЕР -->
<div style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); padding: 60px; border-radius: 30px; text-align: center; margin: 40px 0; border: 2px solid rgba(219, 184, 184, 0.3); box-shadow: 0 20px 50px rgba(219, 184, 184, 0.15);">
    <h2 style="font-size: 48px; color: var(--dusty-rose); margin-bottom: 20px;">Beauty Manager</h2>
    <p style="font-size: 20px; max-width: 600px; margin: 0 auto; color: var(--text-dark);">Удобная онлайн-запись в салон красоты. Профессиональные мастера, комфортная атмосфера.</p>
    <a href="@Url.Action("Create", "Appointment")" class="btn" style="margin-top: 30px;">Записаться онлайн</a>
</div>

<!-- ПРЕИМУЩЕСТВА -->
<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin: 60px 0;">
    <div style="text-align: center; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); padding: 30px; border-radius: 15px; border: 1px solid rgba(219, 184, 184, 0.2);">
        <i class="fas fa-calendar-check" style="font-size: 48px; color: var(--dusty-rose); margin-bottom: 15px;"></i>
        <h3 style="color: var(--dusty-rose);">Удобная запись</h3>
        <p style="color: var(--text-dark); opacity: 0.8;">Онлайн запись 24/7</p>
    </div>
    <div style="text-align: center; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); padding: 30px; border-radius: 15px; border: 1px solid rgba(219, 184, 184, 0.2);">
        <i class="fas fa-users" style="font-size: 48px; color: var(--dusty-rose); margin-bottom: 15px;"></i>
        <h3 style="color: var(--dusty-rose);">Профессионалы</h3>
        <p style="color: var(--text-dark); opacity: 0.8;">Опытные мастера</p>
    </div>
    <div style="text-align: center; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); padding: 30px; border-radius: 15px; border: 1px solid rgba(219, 184, 184, 0.2);">
        <i class="fas fa-gem" style="font-size: 48px; color: var(--dusty-rose); margin-bottom: 15px;"></i>
        <h3 style="color: var(--dusty-rose);">Качество</h3>
        <p style="color: var(--text-dark); opacity: 0.8;">Премиум материалы</p>
    </div>
</div>

<!-- ПОПУЛЯРНЫЕ УСЛУГИ -->
<h3 style="font-size: 28px; color: var(--dusty-rose); margin: 40px 0 20px;">Популярные услуги</h3>

<div class="card-grid">
    @foreach (var item in Model.Take(3))
    {
        <div class="card">
            <div class="card-image">
                <i class="fas fa-spa"></i>
            </div>
            <div class="card-content">
                <h3 class="card-title">@item.Name</h3>
                <p>@item.Description</p>
                <p class="card-price">@item.Price.ToString("C0")</p>
                <a href="@Url.Action("Create", "Appointment", new { serviceId = item.Id })" class="btn" style="padding: 8px 20px;">Записаться</a>
            </div>
        </div>
    }
</div>