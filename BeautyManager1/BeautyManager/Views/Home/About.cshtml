@{
    ViewData["Title"] = "О салоне";
}

<div class="page-title">
    <h2>О салоне красоты МАРМАРА</h2>
    <p>Мы создаем красоту с 2015 года</p>
</div>

<div style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); padding: 40px; border-radius: 20px; border: 2px solid rgba(219, 184, 184, 0.3); box-shadow: 0 20px 50px rgba(219, 184, 184, 0.15);">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center;">
        <div>
            <h3 style="color: var(--dusty-rose); margin-bottom: 20px;">Наша философия</h3>
            <p style="color: var(--text-dark); margin-bottom: 15px;">Салон красоты "Мармара" - это пространство гармонии и красоты. Мы используем только профессиональную косметику и следим за трендами.</p>
            <p style="color: var(--text-dark); opacity: 0.8; margin-bottom: 15px;">Наши мастера регулярно повышают квалификацию и проходят обучение.</p>
            <p style="color: var(--text-dark); opacity: 0.8;">Мы гарантируем индивидуальный подход к каждому клиенту.</p>
        </div>
        <div style="background: linear-gradient(135deg, var(--light-blue), var(--peach)); height: 300px; border-radius: 20px; display: flex; align-items: center; justify-content: center; border: 2px solid rgba(219, 184, 184, 0.3);">
            <i class="fas fa-gem" style="font-size: 100px; color: var(--dusty-rose);"></i>
        </div>
    </div>
</div>