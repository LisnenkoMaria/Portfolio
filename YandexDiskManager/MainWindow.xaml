<Window x:Class="YandexDiskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YandexDiskManager"
        mc:Ignorable="d"
        Title="Yandex Disk Manager" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="14"
        Background="#252525"
        x:Name="ThisWindow"
        SizeChanged="Window_SizeChanged"
        LocationChanged="Window_LocationChanged"
        Closing="MainWindow_Closing">

    <Window.Resources>
        <SolidColorBrush x:Key="YandexYellow" Color="#FFCC00"/>
        <SolidColorBrush x:Key="YandexTextBlack" Color="#000000"/>
        <SolidColorBrush x:Key="YandexSelection" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="YandexSidebar" Color="#252525"/>
        <SolidColorBrush x:Key="YandexWhite" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="YandexBlue" Color="#3078C0"/>
        <SolidColorBrush x:Key="BorderColor" Color="#444444"/>

        <Style x:Key="AccountComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <Button Grid.Column="1" Content="✕" Click="BtnRemoveAccount_Click" 
                                        Width="20" Height="20" 
                                        Background="Transparent" Foreground="#888"
                                        FontSize="10" FontWeight="Bold" 
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="Выйти из аккаунта">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#444"/>
                                                    <Setter Property="Foreground" Value="#FF6666"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccountComboBoxStyle" TargetType="ComboBox">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          ClickMode="Press" Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border" 
                                                Background="#2C2C2C" 
                                                BorderBrush="{StaticResource BorderColor}" 
                                                BorderThickness="1" 
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>

                                                <ContentPresenter x:Name="ContentSite" 
                                                                  IsHitTestVisible="False" 
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBox}}"
                                                                  ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBox}}"
                                                                  Margin="12,0,0,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left">
                                                </ContentPresenter>

                                                <Path x:Name="arrow" Grid.Column="1" 
                                                      Fill="{StaticResource TextSecondary}"
                                                      Data="M0,0 L4,4 L8,0" 
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      IsHitTestVisible="False"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource YandexBlue}"/>
                                                <Setter TargetName="arrow" Property="Fill" Value="{StaticResource TextPrimary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="Popup" 
                                   AllowsTransparency="True" 
                                   Focusable="False" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   Placement="Bottom" 
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" 
                                        Background="#2C2C2C" 
                                        BorderThickness="1" 
                                        BorderBrush="{StaticResource BorderColor}" 
                                        CornerRadius="6" 
                                        MinWidth="{Binding ActualWidth, ElementName=ToggleButton}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                                    </Border.Effect>

                                    <StackPanel>
                                        <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>

                                        <Rectangle Height="1" Fill="{StaticResource BorderColor}" Margin="0,2"/>

                                        <Button x:Name="PART_BtnAdd" Content="+ Подключить диск" 
                                                Click="BtnAddAccount_Click"
                                                Background="Transparent" Foreground="{StaticResource YandexYellow}"
                                                FontWeight="SemiBold"
                                                Height="34" BorderThickness="0" Cursor="Hand"
                                                HorizontalContentAlignment="Left" Padding="10,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3D3D3D"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Grid.IsSharedSizeScope" Value="True" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border x:Name="Border" 
                                Background="#2C2C2C" 
                                BorderThickness="1" 
                                BorderBrush="{StaticResource BorderColor}"
                                CornerRadius="8" 
                                Padding="4">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" Color="Black" Opacity="0.4" ShadowDepth="4"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="4" 
                                Margin="2"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="Icon" 
                                                  ContentSource="Icon" 
                                                  Margin="8,0,12,0" 
                                                  VerticalAlignment="Center" 
                                                  Width="16" Height="16"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                                <ContentPresenter ContentSource="Header" 
                                                  Grid.Column="1" 
                                                  Margin="0,6" 
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Background" Value="#454545"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1" Background="{TemplateBinding Background}" Margin="12,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <ContextMenu x:Key="FileSystemContextMenu" Background="{StaticResource YandexWhite}"  BorderBrush="{StaticResource BorderColor}">
            <MenuItem x:Name="miOpen" Header="Открыть" Click="Menu_Open_Click">
                <MenuItem.Icon>
                    <Image Source="/Icons/folgerIcon.ico"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator Background="{StaticResource BorderColor}"/>
            <MenuItem x:Name="miCopy" Header="Копировать" Click="Menu_Copy_Click">
                <MenuItem.Icon>
                    <Image Source="/Icons/file.ico"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="miCut" Header="Вырезать" Click="Menu_Cut_Click">
                <MenuItem.Icon>
                    <Image Source="/Icons/scissor.ico"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem x:Name="miPaste" Header="Вставить" Click="Menu_Paste_Click">
                <MenuItem.Icon>
                    <Image Source="/Icons/paste.ico"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator Background="{StaticResource BorderColor}"/>

            <MenuItem x:Name="miRename" Header="Переименовать" Click="Menu_Rename_Click">
                <MenuItem.Icon>
                    <Image Source="/Icons/rename.ico"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem x:Name="miDelete" Header="Удалить" Click="Menu_Delete_Click">
                <MenuItem.Icon>
                    <Image Source="/Icons/delete.ico"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <Style TargetType="Button" x:Key="MaterialButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextPrimary}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#20000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButton" BasedOn="{StaticResource MaterialButton}">
            <Setter Property="Background" Value="{StaticResource YandexYellow}"/>
            <Setter Property="Foreground" Value="{StaticResource YandexTextBlack}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.1"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFD633"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="SearchTextBox">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource YandexSelection}"/>
            <Setter Property="Background" Value="{StaticResource YandexSelection}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="4" Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource YandexYellow}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ContextMenu" Value="{StaticResource FileSystemContextMenu}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="8,10"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource YandexSelection}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource YandexSelection}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="FileDataTemplate">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="370"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="Icon" Source="/Icons/file.ico" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" 
                   Text="{Binding Name}" 
                   VerticalAlignment="Center" 
                   Margin="5,0,10,0" 
                   TextTrimming="CharacterEllipsis" 
                   ToolTip="{Binding Name}"
                   Foreground="{StaticResource TextPrimary}"/>

                <TextBlock Grid.Column="3" 
                   Text="{Binding FormattedSize}" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Right" 
                   Margin="0,0,10,0"
                   Foreground="#999999"
                   FontSize="12"/>
            </Grid>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter TargetName="Icon" Property="Source" Value="/Icons/folgerIcon.ico"/>

                </DataTrigger>
                <DataTrigger Binding="{Binding Name}" Value="C:\">
                    <Setter TargetName="Icon" Property="Source" Value="/Icons/disk.ico"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource YandexSidebar}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid Margin="15,20,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="55" MinHeight="45"/>
                    <RowDefinition Height="Auto" MinHeight="47.62"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Text="Компьютер" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="5,0,0,20"/>

                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnWindowsUp" Content="↑" Width="32" 
                            FontWeight="Bold"
                            Style="{StaticResource MaterialButton}" 
                            Click="BtnWindowsUp_Click" ToolTip="На уровень вверх" BorderThickness="4" BorderBrush="#E0E0E0" Height="32" VerticalAlignment="Top"/>

                    <TextBox x:Name="txtWindowsCurrentPath" Grid.Column="1" Margin="10,0,0,0" 
                             Style="{StaticResource SearchTextBox}"
                             IsReadOnly="True" VerticalContentAlignment="Center"/>
                </Grid>

                <Border Grid.Row="2" Background="Transparent" Margin="0,5,0,5" Padding="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="370"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="1" Text="Имя" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" FontSize="11"/>

                        <TextBlock Grid.Column="2" Text="Размер" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    </Grid>
                </Border>

                <ListBox x:Name="lstWindowsFiles" Grid.Row="3"
                         ContextMenu="{StaticResource FileSystemContextMenu}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         BorderThickness="0" Background="Transparent"
                         MouseDoubleClick="Universal_MouseDoubleClick"
                         SelectionMode="Extended"
                         PreviewMouseLeftButtonDown="Universal_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="Universal_PreviewMouseMove"
                         PreviewMouseLeftButtonUp="Universal_PreviewMouseLeftButtonUp"
                         ContextMenuOpening="Universal_ContextMenuOpening"
                         ItemContainerStyle="{StaticResource FileItemStyle}"
                         ItemTemplate="{StaticResource FileDataTemplate}"
                         AllowDrop="True"
                         DragEnter="LstWindowsFiles_DragEnter"
                         Drop="LstWindowsFiles_Drop"/>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                      Background="{StaticResource BorderColor}" ShowsPreview="True"/>

        <Border Grid.Column="2" Background="{StaticResource YandexSidebar}">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="lstAccounts"
                              Grid.Column="2"
                              SelectionChanged="LstAccounts_SelectionChanged"
                              Style="{StaticResource AccountComboBoxStyle}"
                              ItemContainerStyle="{StaticResource AccountComboBoxItemStyle}">

                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Login}" 
                                           Foreground="{StaticResource TextPrimary}" 
                                           FontWeight="SemiBold" 
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnYandexDiskUp" Content="↑" Width="32" Height="32" 
                            FontWeight="Bold"
                            Style="{StaticResource MaterialButton}" 
                            Click="BtnYandexDiskUp_Click" ToolTip="На уровень вверх" BorderThickness="1" BorderBrush="#E0E0E0"/>

                    <TextBox x:Name="txtYandexDiskCurrentPath" Grid.Column="1" Margin="10,0,0,0" 
                             Style="{StaticResource SearchTextBox}"
                             IsReadOnly="True" VerticalContentAlignment="Center"/>
                </Grid>


                <Border Grid.Row="2" Background="Transparent" Margin="0,5,0,5" Padding="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="370"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="1" Text="Имя" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" FontSize="11"/>

                        <TextBlock Grid.Column="2" Text="Размер" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    </Grid>
                </Border>


                <ListBox x:Name="lstYandexDiskFiles"
                         Margin="0"
                         Grid.Row="3" 
                         ContextMenu="{StaticResource FileSystemContextMenu}"
                         BorderThickness="0" Background="Transparent"
                         MouseDoubleClick="Universal_MouseDoubleClick"
                         SelectionMode="Extended"
                         PreviewMouseLeftButtonDown="Universal_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="Universal_PreviewMouseMove"
                         PreviewMouseLeftButtonUp="Universal_PreviewMouseLeftButtonUp"
                         ContextMenuOpening="Universal_ContextMenuOpening"
                         ItemContainerStyle="{StaticResource FileItemStyle}"
                         ItemTemplate="{StaticResource FileDataTemplate}"/>
            </Grid>
        </Border>

        <Grid x:Name="PopupAnchor" Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="360" Height="1" Margin="20,0,0,20" Background="Transparent"/>

        <Popup x:Name="DownloadPopup" Placement="Top" PlacementTarget="{Binding ElementName=PopupAnchor}" AllowsTransparency="True" StaysOpen="True">
            <Border Background="{StaticResource YandexWhite}" CornerRadius="8" Width="360" BorderThickness="1" BorderBrush="{StaticResource BorderColor}">

                <StackPanel>
                    <Grid Background="{StaticResource YandexSidebar}" Height="44">
                        <TextBlock Text="Загрузки" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        <Button x:Name="btnTogglePopup" Content="▼" Click="BtnTogglePopup_Click" HorizontalAlignment="Right" Width="40" Background="Transparent" Foreground="{StaticResource TextSecondary}" BorderThickness="0"/>
                    </Grid>

                    <ListBox x:Name="lstDownloads" Background="{StaticResource YandexWhite}" BorderThickness="0" ItemsSource="{Binding ElementName=ThisWindow, Path=ActiveDownloads}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled" MaxHeight="300">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,8" Width="320">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="📄" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource TextSecondary}"/>

                                    <StackPanel Grid.Column="1" Margin="10,0">
                                        <TextBlock Text="{Binding FileName}" FontWeight="Normal" TextTrimming="CharacterEllipsis" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="✕" Command="{Binding CancelCommand}" Style="{StaticResource MaterialButton}" Width="24" Height="24" FontSize="10" Padding="0"/>

                                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="3" Value="{Binding Progress}" Height="3" Margin="0,8,0,0" Background="#F0F0F0" Foreground="{StaticResource YandexYellow}" BorderThickness="0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="RenamePopup" Placement="Center" PlacementTarget="{Binding ElementName=MainGrid}" StaysOpen="False" AllowsTransparency="True">
            <Border Background="{StaticResource YandexSidebar}" CornerRadius="12" Padding="24" Width="340">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.2" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Переименовать файл" FontWeight="Bold" FontSize="18" Margin="0,0,0,15" Foreground="{StaticResource TextPrimary}"/>
                    <TextBox x:Name="txtRenameInput" Style="{StaticResource SearchTextBox}" Margin="0,0,0,25" Height="36" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Click="BtnRenameCancel_Click" Style="{StaticResource MaterialButton}" Foreground="{StaticResource TextSecondary}" Margin="0,0,15,0"/>
                        <Button Content="Сохранить" Click="BtnRenameOk_Click" Style="{StaticResource PrimaryButton}" Padding="24,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

    </Grid>
</Window>